# Origem pública e configuração do Supabase. A chave anon é pública; nunca use a service role no frontend.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Contas autorizadas no backend, separadas por vírgula.
ADMIN_IDS=
ADMIN_EMAILS=
AUTOMATION_EMAILS=

# Origens HTTPS autorizadas a chamar as funções, separadas por vírgula.
APP_ORIGINS=

# Segredo aleatório usado somente para pseudonimizar chaves de rate limit.
RATE_LIMIT_SALT=

# Provedores de IA usados exclusivamente nas funções server-side.
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=
GROQ_FALLBACK_MODEL=
FEGUINHO_MODEL_GERAR=
FEGUINHO_MODEL_DISSECAR=
FEGUINHO_MODEL_MODELAR=
FURTADO_MODEL=
VSL_DISSECTOR_MODEL=

# Coleta autorizada do Meta Ads via Apify.
APIFY_TOKEN=
FB_ADS_ACTOR=

# BigQuery: use somente uma das duas formas de JSON; mantenha a conta com acesso de leitura mínimo.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_EXPECTED_KEY_ID=

# Credenciais exclusivas das automações de CI; nunca são variáveis públicas do site.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BOT_EMAIL=
SUPABASE_BOT_PASSWORD=
